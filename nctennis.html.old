<!doctype html>
<html lang='en'>
<head>
  <meta charset='utf-8'>
  <meta name='viewport' content='width=device-width, initial-scale=1'>
  <title>NC Adult League Tennis</title>
  <style>
    :root { --navy:#0b1f3a; --green:#0f766e; --lime:#ccff00; --ink:#102033; --muted:#667085; --card:#ffffff; --line:#e6edf3; --bg:#f5f8fb; --soft:#eaf8f5; }
    * { box-sizing:border-box; }
    body { margin:0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif; background:var(--bg); color:var(--ink); }
    a { color:inherit; text-decoration:none; }
    .topbar { background:var(--navy); color:white; padding:18px 28px; position:sticky; top:0; z-index:5; box-shadow:0 2px 18px rgba(0,0,0,.16); }
    .nav { max-width:1180px; margin:auto; display:flex; align-items:center; justify-content:space-between; gap:18px; flex-wrap:wrap; }
    .brand { font-weight:900; letter-spacing:-.03em; font-size:22px; }
    .navlinks { display:flex; gap:18px; font-size:14px; color:#ffffff; flex-wrap:wrap; justify-content:flex-end; row-gap:8px; }
    .hero { background:linear-gradient(135deg, #0b1f3a 0%, #0f766e 75%); color:white; padding:58px 28px 44px; }
    .hero-inner { max-width:1180px; margin:auto; display:grid; grid-template-columns:1.4fr .8fr; gap:28px; align-items:end; }
    .eyebrow { display:inline-flex; gap:8px; align-items:center; background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.22); border-radius:999px; padding:7px 12px; font-size:13px; color:#edf7f4; }
    .dot { width:9px; height:9px; border-radius:50%; background:var(--lime); display:inline-block; }
    h1 { font-size:54px; line-height:.95; letter-spacing:-.06em; margin:18px 0 14px; }
    .subtitle { color:#dceeea; font-size:18px; max-width:760px; line-height:1.45; }
    .hero-card { background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.18); border-radius:24px; padding:22px; backdrop-filter:blur(8px); }
    .hero-card .label { color:#c9efe8; font-size:13px; text-transform:uppercase; letter-spacing:.08em; }
    .hero-card .big { font-size:38px; font-weight:900; margin-top:6px; }
    .wrap { max-width:1180px; margin:0 auto; padding:28px; }
    .stats { display:grid; grid-template-columns:repeat(4, 1fr); gap:16px; margin-top:-42px; position:relative; z-index:2; }
    .stat { background:var(--card); border:1px solid var(--line); border-radius:20px; padding:18px; box-shadow:0 10px 30px rgba(16,32,51,.08); }
    .stat .num { font-size:30px; font-weight:900; letter-spacing:-.04em; }
    .stat .txt { color:var(--muted); font-size:13px; margin-top:4px; }
    .grid { display:grid; grid-template-columns:1.2fr .8fr; gap:20px; margin-top:22px; }
    .card { background:var(--card); border:1px solid var(--line); border-radius:22px; padding:20px; box-shadow:0 8px 24px rgba(16,32,51,.05); overflow:hidden; }
    .card h2 { margin:0 0 4px; letter-spacing:-.03em; font-size:22px; }
    .card h3 { margin:0 0 4px; letter-spacing:-.02em; font-size:18px; color:var(--navy); }
    .card p { margin:0 0 14px; color:var(--muted); font-size:14px; }
    .league-nav { display:flex; flex-wrap:wrap; gap:8px; margin:18px 0 4px; }
    .league-nav a { display:inline-flex; padding:7px 10px; border-radius:999px; background:#fff; border:1px solid var(--line); color:var(--green); font-size:12px; font-weight:800; }
    .league-card { margin-top:18px; }
    table { width:100%; border-collapse:collapse; }
    th, td { padding:10px 8px; border-bottom:1px solid #edf2f6; font-size:13px; text-align:left; vertical-align:middle; }
    th { color:#53657a; font-size:12px; text-transform:uppercase; letter-spacing:.05em; background:#fbfdff; }
    tr:hover td { background:#fbfffd; }
    .rank { font-weight:900; color:var(--navy); }
    .pill { display:inline-flex; align-items:center; border-radius:999px; padding:3px 8px; background:var(--soft); color:var(--green); font-weight:800; font-size:12px; }
    .up { color:#047857; font-weight:900; }
    .down { color:#b42318; font-weight:900; }
    .footer { color:#728197; font-size:12px; padding:24px 0 10px; text-align:center; }
    .section-list { display:grid; gap:10px; }
    .section-row { display:flex; justify-content:space-between; gap:12px; border:1px solid var(--line); border-radius:16px; padding:12px; background:#fbfdff; }
    .section-row strong { color:var(--navy); }
    .small { color:var(--muted); font-size:12px; }
    details { border-radius:14px; }
    summary { cursor:pointer; list-style:none; }
    summary::-webkit-details-marker { display:none; }
    .team-summary { display:flex; align-items:center; justify-content:space-between; gap:10px; }
    .team-summary:after { content:'Show roster'; color:var(--green); font-size:12px; font-weight:900; white-space:nowrap; }
    details[open] .team-summary:after { content:'Hide roster'; }
    .roster-box { margin-top:10px; padding:10px; border:1px solid var(--line); border-radius:14px; background:#fbfdff; }
    .roster-grid { display:grid; grid-template-columns:1.5fr .6fr .6fr; gap:0; }
    .roster-grid div { padding:6px 8px; border-bottom:1px solid #edf2f6; font-size:12px; }
    .roster-grid .head { color:#53657a; font-size:11px; text-transform:uppercase; letter-spacing:.05em; font-weight:900; background:#f7fafc; }
    .player-groups { display:grid; gap:12px; margin-top:14px; }
    .player-group { border:1px solid var(--line); border-radius:18px; background:#fff; overflow:hidden; }
    .player-group summary { padding:14px 16px; background:#fbfdff; font-weight:900; color:var(--navy); display:flex; justify-content:space-between; gap:12px; }
    .player-group summary span { color:var(--muted); font-weight:700; font-size:12px; }
    .player-group table { margin:0; }
    @media (max-width: 860px) {
      .hero-inner, .grid { grid-template-columns:1fr; }
      .stats { grid-template-columns:repeat(2,1fr); }
      h1 { font-size:40px; }
      .nav { align-items:flex-start; flex-wrap:wrap; }
      .navlinks { display:flex; width:100%; justify-content:flex-start; gap:12px; font-size:13px; margin-top:8px; flex-wrap:wrap; }
      .wrap { padding:18px; }
    }
    @media (max-width: 520px) { .stats { grid-template-columns:1fr; } th, td { font-size:12px; padding:8px 5px; } .roster-grid { grid-template-columns:1fr .45fr .45fr; } }
    </style>
</head>
<body>
  <header class='topbar'>
    <div class='nav'>
      <div class='brand'>NC Adult League Tennis</div>
      <nav class='navlinks'>
        <a href='#teams'>Power Rankings</a>
        <a href='#players'>Players</a>
        <a href='#movers'>Movers</a>
        <a href='#sections'>Sections</a>
      </nav>
    </div>
  </header>
  <section class='hero'>
    <div class='hero-inner'>
      <div>
        <div class='eyebrow'><span class='dot'></span> Spring 2026 test dashboard</div>
        <h1>NC Adult League Tennis</h1>
        <div class='subtitle'>Power rankings, player movers, and tournament intelligence for North Carolina adult league tennis. Initial coverage focuses on NC Adult 55+ and 65+ leagues across configured genders and levels.</div>
      </div>
      <div class='hero-card'>
        <div class='label'>Latest Run</div>
        <div class='big'>2026-05-20</div>
        <div class='small' style='color:#dceeea'>2026-05-20 16:31:45 EDT</div>
      </div>
    </div>
  </section>

  <main class='wrap'>
