      <div class='stat'><div class='num'>4260</div><div class='txt'>Players tracked</div></div>
      <div class='stat'><div class='num'>14</div><div class='txt'>League buckets</div></div>
      <div class='stat'><div class='num'>14</div><div class='txt'>NC sections</div></div>
    </section>

    
